# ─── Required ────────────────────────────────────────────────
# Knowledge Base ID from your Bedrock console
KNOWLEDGE_BASE_ID=your-kb-id-here

# AWS Region
AWS_REGION=us-east-1

# ─── Auth (optional) ─────────────────────────────────────────
# Simple API key for dev/internal use. If unset, open access (intranet mode).
# Replace with Cognito for production.
API_KEY=
NEXT_PUBLIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bedrock_kb_chat

# ─── Model ───────────────────────────────────────────────────
# Override the default model ARN (default: global.anthropic.claude-sonnet-4-6)
# BEDROCK_MODEL_ARN=global.anthropic.claude-sonnet-4-6

# ─── Two-Step RAG: Retrieve + OpenAI Generate (optional) ─────
# When set, Bedrock only handles retrieval; generation uses OpenAI-compatible API.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
